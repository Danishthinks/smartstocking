rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Restrict stock updates to quantity + lastUpdatedBy only.
    function validProductQuantityUpdate() {
      return changedKeys().hasOnly(['quantity', 'lastUpdatedBy']) &&
        request.resource.data.quantity is int &&
        request.resource.data.quantity >= 0 &&
        request.resource.data.lastUpdatedBy == request.auth.uid;
    }

    // Used by transfer operations that move stock between warehouses.
    function validProductTransferUpdate() {
      return changedKeys().hasOnly(['quantity', 'warehouse', 'lastUpdatedBy']) &&
        request.resource.data.quantity is int &&
        request.resource.data.quantity >= 0 &&
        request.resource.data.warehouse is string &&
        request.resource.data.lastUpdatedBy == request.auth.uid;
    }

    // Allow non-stock field edits while requiring ownership marker.
    function validProductNonStockUpdate() {
      return !changedKeys().hasAny(['quantity']) &&
        request.resource.data.lastUpdatedBy == request.auth.uid;
    }

    function validSalesCreate() {
      return request.resource.data.keys().hasOnly([
          'orderId',
          'productIds',
          'productNames',
          'items',
          'totalItems',
          'totalQuantity',
          'salePrice',
          'timestamp',
          'soldBy',
          'soldByEmail'
        ]) &&
        request.resource.data.orderId is string &&
        request.resource.data.productIds is list &&
        request.resource.data.productNames is list &&
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.totalItems is int &&
        request.resource.data.totalItems == request.resource.data.items.size() &&
        request.resource.data.totalQuantity is int &&
        request.resource.data.totalQuantity > 0 &&
        request.resource.data.salePrice is number &&
        request.resource.data.salePrice >= 0 &&
        request.resource.data.timestamp is timestamp &&
        request.resource.data.soldBy == request.auth.uid &&
        request.resource.data.soldByEmail == request.auth.token.email;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (validProductQuantityUpdate() || validProductTransferUpdate() || validProductNonStockUpdate());
      allow delete: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && validSalesCreate();
      allow update, delete: if false;
    }

    match /ecommerceOrders/{orderId} {
      allow read, update: if isSignedIn();
      allow create, delete: if false;
    }

    match /warehouses/{warehouseId} {
      allow read, write: if isSignedIn();
    }

    match /logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.user is string;
      allow update, delete: if false;
    }
  }
}
